# ============================================
# AGENT BOSS — Environment Variables
# ============================================
# Copy this to .env and fill in your keys.
# Never commit real keys. Rotate after the hackathon.

# ---------- Database ----------
# Local dev (default): sqlite
DATABASE_URL="file:./dev.db"

# Production: postgres (Neon / Supabase)
# DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# ---------- Arc Blockchain ----------
ARC_RPC_URL="https://rpc.arc.testnet"
ARC_CHAIN_ID="123456"
ARC_USDC_ADDRESS="0x..."
ARC_PLATFORM_WALLET="0x..."
ARC_PLATFORM_PRIVATE_KEY=""

# ---------- Circle App Kit (Wallets) ----------
CIRCLE_API_KEY=""
CIRCLE_ENTITY_SECRET=""
CIRCLE_WALLET_SET_ID=""

# ---------- x402 Protocol ----------
X402_FACILITATOR_URL="https://x402.coinbase.com"
X402_NETWORK="arc-testnet"

# ---------- AI Provider Keys ----------
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
REPLICATE_API_TOKEN=""

# ---------- App Config ----------
NEXT_PUBLIC_APP_NAME="Agent Boss"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
PLATFORM_FEE_BPS="100"  # 1% in basis points
